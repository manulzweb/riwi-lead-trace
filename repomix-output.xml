import { escapeHtml } from "../../utils/validators";
import { showToast } from "../../components/alerts";

let evaluables = [];
let evaluations = [];
let activePeriod = null;
let currentFilter = "all"; // 'all' | 'team_leader' | 'tutor'

export const renderEvaluables = () => {
  return `
    ${navBarComponent()}
